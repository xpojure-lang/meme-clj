(ns wlj-lang.stages-test
  (:require [clojure.test :refer [deftest is testing]]
            [wlj-lang.api :as wlj]))

(defn- w [s] (wlj/wlj->forms s))

;; ---------------------------------------------------------------------------
;; Calls — square brackets, no adjacency
;; ---------------------------------------------------------------------------

(deftest basic-call
  (is (= [(list 'f 'x 'y)] (w "f[x, y]")))
  (is (= [(list 'f 'x 'y)] (w "f [x, y]")))  ;; no adjacency!
  (is (= [(list 'f)] (w "f[]"))))

(deftest nested-call
  (is (= [(list 'f (list 'g 'x))] (w "f[g[x]]")))
  (is (= [(list 'f (list 'g (list 'h 'x)))] (w "f[g[h[x]]]"))))

(deftest call-with-expr-args
  (is (= [(list 'f (list '+ 1 2))] (w "f[1 + 2]"))))

;; ---------------------------------------------------------------------------
;; Data — curly braces → vectors
;; ---------------------------------------------------------------------------

(deftest list-literal
  (is (= [[1 2 3]] (w "{1, 2, 3}")))
  (is (= [[[1 2] [3 4]]] (w "{{1, 2}, {3, 4}}")))
  (is (= [[]] (w "{}"))))

;; ---------------------------------------------------------------------------
;; Arithmetic
;; ---------------------------------------------------------------------------

(deftest arithmetic
  (is (= [(list '+ 2 (list '* 3 4))] (w "2 + 3 * 4")))
  (is (= [(list '* (list '+ 2 3) 4)] (w "(2 + 3) * 4")))
  (is (= [(list '/ 10 2)] (w "10 / 2"))))

(deftest power-right-assoc
  (is (= [(list 'Math/pow 2 (list 'Math/pow 3 2))] (w "2 ^ 3 ^ 2"))))

(deftest unary-minus
  (is (= [(list '+ (list '- 5) 3)] (w "-5 + 3"))))

;; ---------------------------------------------------------------------------
;; Comparison and logical
;; ---------------------------------------------------------------------------

(deftest comparison
  (is (= [(list '= 'x 'y)] (w "x == y")))
  (is (= [(list 'not= 'x 'y)] (w "x != y")))
  (is (= [(list '< 'x 'y)] (w "x < y")))
  (is (= [(list '> 'x 'y)] (w "x > y")))
  (is (= [(list '<= 'x 'y)] (w "x <= y")))
  (is (= [(list '>= 'x 'y)] (w "x >= y"))))

(deftest logical
  (is (= [(list 'and 'a 'b)] (w "a && b")))
  (is (= [(list 'or 'a 'b)] (w "a || b")))
  (is (= [(list 'not 'x)] (w "!x"))))

;; ---------------------------------------------------------------------------
;; Assignment
;; ---------------------------------------------------------------------------

(deftest assignment
  (is (= [(list 'def 'x 10)] (w "x = 10"))))

;; ---------------------------------------------------------------------------
;; Compound expression
;; ---------------------------------------------------------------------------

(deftest compound
  (is (= [(list 'do 'a 'b 'c)] (w "a; b; c"))))

;; ---------------------------------------------------------------------------
;; Rules and associations
;; ---------------------------------------------------------------------------

(deftest rule
  (is (= [['a 'b]] (w "a -> b"))))

(deftest association
  (is (= [{"a" 1, "b" 2}] (w "<| \"a\" -> 1, \"b\" -> 2 |>"))))

;; ---------------------------------------------------------------------------
;; Part (indexing)
;; ---------------------------------------------------------------------------

(deftest part
  (is (= [(list 'nth 'list 2)] (w "list[[2]]"))))

;; ---------------------------------------------------------------------------
;; Literals
;; ---------------------------------------------------------------------------

(deftest literals
  (is (= [42] (w "42")))
  (is (= [3.14] (w "3.14")))
  (is (= [true] (w "True")))
  (is (= [false] (w "False")))
  (is (= [nil] (w "Null")))
  (is (= ["hello"] (w "\"hello\""))))

;; ---------------------------------------------------------------------------
;; Comments
;; ---------------------------------------------------------------------------

(deftest comments
  (is (= [(list '+ 1 2)] (w "(* add two numbers *) 1 + 2")))
  (is (= [(list '+ 1 2)] (w "1 + 2 (* trailing *)"))))

;; ---------------------------------------------------------------------------
;; to-clj
;; ---------------------------------------------------------------------------

(deftest to-clj
  (is (= "(+ 2 (* 3 4))" (wlj/wlj->clj "2 + 3 * 4")))
  (is (= "(f (g x))" (wlj/wlj->clj "f[g[x]]")))
  (is (= "(def x 10)" (wlj/wlj->clj "x = 10"))))
