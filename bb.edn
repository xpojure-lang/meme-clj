{:paths ["src" "test"]
 :tasks {meme {:doc "meme CLI: run, repl, convert, format, version"
              :task (do (require '[meme.alpha.runtime.cli])
                        (apply (resolve 'meme.alpha.runtime.cli/-main) *command-line-args*))}
         test-meme {:doc "Run all .meme tests (eval + fixture)"
                   :task (do (require '[meme.alpha.test-runner])
                             (let [fails ((resolve 'meme.alpha.test-runner/run-all-meme-tests))]
                               (System/exit (if (zero? fails) 0 1))))}
         test-cljs {:doc "Run ClojureScript tests under Node.js"
                    :task (try
                            (shell "clojure" "-M:cljs-test")
                            (finally
                              (babashka.fs/delete-tree "cljs-test-runner-out")))}
         test-all {:doc "Run all test suites (Babashka + JVM + ClojureScript)"
                   :task (do (shell "bb" "test-meme")
                             (println)
                             (shell "clojure" "-X:test")
                             (println)
                             (run 'test-cljs))}}}
