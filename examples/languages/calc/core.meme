; calc — a tiny arithmetic language built on meme.
; Prelude: defines simplification rules and a `simplify` function.

require('[meme.rewrite :as rw])

def(rules
  [rw/rule(list('+ '?a 0) '?a)
   rw/rule(list('+ 0 '?a) '?a)
   rw/rule(list('* '?a 1) '?a)
   rw/rule(list('* 1 '?a) '?a)
   rw/rule(list('* '?a 0) 0)
   rw/rule(list('* 0 '?a) 0)
   rw/rule(list('- '?a 0) '?a)
   rw/rule(list('/ '?a 1) '?a)])

defn(simplify [expr] rw/rewrite(rules expr))
