require('[cheshire.core :as json])

defn(stars
  [owner repo]
  let(
    [
      url
      str("https://api.github.com/repos/" owner "/" repo)
      resp
      slurp(url)
      data
      json/parse-string(resp true)
      count
      :stargazers_count(data)
    ]
    println(str(owner "/" repo ": " count " ⭐"))))

stars("beme-lang" "meme-clj")
