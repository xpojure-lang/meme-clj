; Data literals — every type

;; nil, true, false
assert(=(nil?(nil) true))
assert(=(true?(true) true))
assert(=(false?(false) true))

;; integers
assert(=(+(1 2) 3))
assert(=(*(100 100) 10000))

;; negative numbers
assert(=(-1 -1))
assert(=(+(-1 1) 0))

;; floats
assert(=(+(1.5 1.5) 3.0))

;; ratios
assert(=(+(1/4 1/4) 1/2))
assert(=(*(2/3 3/2) 1))
assert(=(ratio?(1/3) true))

;; strings
assert(=(str("hello" " " "world") "hello world"))
assert(=(count("abc") 3))

;; character literals
assert(=(char?(\a) true))
assert(=(str(\h \i) "hi"))
assert(=(str(\newline) "\n"))
assert(=(str(\space) " "))
assert(=(\tab \tab))

;; keywords — simple
assert(=(keyword("foo") :foo))
assert(=(:a :a))

;; keywords — namespaced
assert(=(:user/name :user/name))

;; symbols
assert(=(symbol("foo") 'foo))
assert(=(symbol?('bar) true))

;; vectors
assert(=(count([1 2 3]) 3))
assert(=(conj([1 2] 3) [1 2 3]))
assert(=(vec([]) []))

;; maps
def(m {:a 1 :b 2 :c 3})
assert(=(count(m) 3))
assert(=(:a(m) 1))
assert(=(:d(assoc(m :d 4)) 4))

;; sets
def(s #{1 2 3})
assert(=(contains?(s 2) true))
assert(=(contains?(s 4) false))
assert(=(count(s) 3))

;; nested data
def(data {:users [{:name "a" :active true}
                    {:name "b" :active false}
                    {:name "c" :active true}]})
assert(=(count(:users(data)) 3))
assert(=(->>(filter(:active :users(data)) count()) 2))

;; regex
assert(=(some?(re-find(#"\d+" "abc123")) true))
assert(=(nil?(re-find(#"\d+" "abc")) true))
assert(=(re-find(#"hello" "hello world") "hello"))
