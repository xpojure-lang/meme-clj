; Integration — full example combining multiple features

defn(transform-accounts [accounts]
  let([
    active filter(:active accounts),
    balanced ->>(active
      map(fn([a] assoc(a :balance *(:balance(a) 1.05))))
      remove(fn([a] neg?(:balance(a)))))
  ]
    reduce(fn([acc {:keys [id balance]}]
      assoc(acc id {:balance balance :status :processed})) {} balanced)))

defn(summarize [accounts]
  let([
    processed transform-accounts(accounts),
    total ->>(processed vals() map(:balance) reduce(+))
  ]
    {:total total :count count(processed) :accounts processed}))

def(accounts [
  {:id :alice   :name "Alice"   :balance 100.0 :active true}
  {:id :bob     :name "Bob"     :balance 200.0 :active true}
  {:id :carol   :name "Carol"   :balance -50.0 :active true}
  {:id :dave    :name "Dave"    :balance 300.0 :active false}
])

def(result summarize(accounts))

; carol removed (negative balance), dave removed (inactive)
assert(=(:count(result) 2))
assert(=(contains?(:accounts(result) :alice) true))
assert(=(contains?(:accounts(result) :bob) true))
assert(=(not(contains?(:accounts(result) :carol)) true))
assert(=(not(contains?(:accounts(result) :dave)) true))

; balances multiplied by 1.05
assert(=(:balance(:alice(:accounts(result))) 105.0))
assert(=(:balance(:bob(:accounts(result))) 210.0))

; total is sum
assert(=(:total(result) 315.0))

; all processed
assert(=(:status(:alice(:accounts(result))) :processed))
assert(=(:status(:bob(:accounts(result))) :processed))
