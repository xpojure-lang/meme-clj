// calc-lang demo — infix math that compiles to Clojure

// arithmetic with standard precedence
let x = 2 + 3 * 4
let y = (2 + 3) * 4

// power is right-associative
let p = 2 ^ 3 ^ 2

// function calls
let area = 3.14159 * 10 ^ 2

// ternary
let sign = x > 0 ? 1 : -1

// print results
println(x)
println(y)
println(p)
println(area)
println(sign)
