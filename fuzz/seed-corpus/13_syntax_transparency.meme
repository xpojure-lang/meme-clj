; Syntax transparency — meme is a syntactic lens, not a normalizer.
; The read→print pipeline must preserve the user's syntax choices.

require('[meme-lang.api :as m])

;; Helper: roundtrip meme source through read→print
defn(rt [src] m/forms->meme(m/meme->forms(src)))

;; ---------------------------------------------------------------
;; Quote: 'x sugar vs quote(x) call — both must roundtrip exactly
;; ---------------------------------------------------------------

;; Sugar forms preserved
assert(=(rt("'foo") "'foo"))
assert(=(rt("'f(x y)") "'f(x y)"))
assert(=(rt("'()") "'()"))

;; Call forms preserved
assert(=(rt("quote(foo)") "quote(foo)"))
assert(=(rt("quote(f(x))") "quote(f(x))"))

;; ---------------------------------------------------------------
;; Deref: @x sugar vs clojure.core/deref(x) call
;; ---------------------------------------------------------------

assert(=(rt("@foo") "@foo"))
assert(=(rt("clojure.core/deref(foo)") "clojure.core/deref(foo)"))

;; ---------------------------------------------------------------
;; Var: #'x sugar vs var(x) call
;; ---------------------------------------------------------------

assert(=(rt("#'foo") "#'foo"))
assert(=(rt("var(foo)") "var(foo)"))

;; ---------------------------------------------------------------
;; Clojure output also preserves syntax choices
;; ---------------------------------------------------------------

defn(rt-clj [src] m/meme->clj(src))

assert(=(rt-clj("'foo") "'foo"))
assert(=(rt-clj("quote(foo)") "(quote foo)"))
assert(=(rt-clj("@foo") "@foo"))
assert(=(rt-clj("clojure.core/deref(foo)") "(clojure.core/deref foo)"))
assert(=(rt-clj("#'foo") "#'foo"))
assert(=(rt-clj("var(foo)") "(var foo)"))

;; ---------------------------------------------------------------
;; Syntax-quote: `form preserved as AST, not expanded at read time
;; ---------------------------------------------------------------

assert(=(rt("`foo") "`foo"))
assert(=(rt("`if(~test ~body)") "`if(~test ~body)"))
assert(=(rt("`do(~@body)") "`do(~@body)"))
assert(=(rt("`[~a ~b]") "`[~a ~b]"))

;; ---------------------------------------------------------------
;; Numeric notation preserved through roundtrip
;; ---------------------------------------------------------------

assert(=(rt("0xFF") "0xFF"))
assert(=(rt("010") "010"))
assert(=(rt("2r1010") "2r1010"))
assert(=(rt("1e2") "1e2"))

;; Standard notation still works
assert(=(rt("42") "42"))
assert(=(rt("3.14") "3.14"))

;; ---------------------------------------------------------------
;; Character escape notation preserved
;; ---------------------------------------------------------------

assert(=(rt("\\u0041") "\\u0041"))
assert(=(rt("\\o101") "\\o101"))

;; Standard chars still work
assert(=(rt("\\a") "\\a"))
assert(=(rt("\\newline") "\\newline"))

;; ---------------------------------------------------------------
;; String unicode escapes preserved
;; ---------------------------------------------------------------

assert(=(rt("\"hello \\u0041\"") "\"hello \\u0041\""))

;; Standard string escapes still work
assert(=(rt("\"hello\\nworld\"") "\"hello\\nworld\""))

;; ---------------------------------------------------------------
;; #() vs fn() — sugar preserved
;; ---------------------------------------------------------------

;; NOTE: The experimental pipeline normalizes bare % to %1
assert(=(rt("#(inc(%))") "#(inc(%1))"))
assert(=(rt("fn([%1] inc(%1))") "fn([%1] inc(%1))"))

;; ---------------------------------------------------------------
;; Set element ordering preserved
;; ---------------------------------------------------------------

assert(=(rt("#{3 1 2}") "#{3 1 2}"))

;; ---------------------------------------------------------------
;; Namespaced maps preserved
;; ---------------------------------------------------------------

assert(=(rt("#:user{:a 1 :b 2}") "#:user{:a 1 :b 2}"))

;; ---------------------------------------------------------------
;; Chained metadata preserved
;; ---------------------------------------------------------------

assert(=(rt("^:a ^:b foo") "^:a ^:b foo"))
