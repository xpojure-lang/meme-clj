ns( calc-lang.run
  "Calc-lang eval pipeline. JVM/Babashka only."
  :require([meme.tools.run :as tools-run] [calc-lang.stages :as stages])
)

defn( run-string [s opts]
  tools-run/run-string(
    s
    {:run-fn       fn([source reader-opts] stages/run(source reader-opts))
     :expand-forms fn([forms _opts] forms)
     :reader-opts  or(opts {})
     :eval         :eval(opts)}
  )
)
