ns( calc-lang.stages
  "Composable pipeline stages for calc-lang."
  :require(
    [meme.tools.parser :as pratt]
    [calc-lang.grammar :as grammar]
    [calc-lang.cst-reader :as cst-reader]
  )
)

defn(step-parse [ctx] assoc(ctx :cst pratt/parse(:source(ctx) grammar/grammar)))

defn( step-read
  [ctx]
  assoc(ctx :forms cst-reader/read-forms(:cst(ctx) :opts(ctx)))
)

defn(run [source opts] ->({:source source :opts opts} step-parse step-read))
